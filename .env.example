# Vercel Postgres connection string (from Vercel dashboard → Storage → Postgres)
DATABASE_URL=postgres://user:password@host/dbname

# JWT signing secret — change this to a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# One-time database setup key — set anything, used to call /api/setup?key=<value>
SETUP_KEY=my-setup-key-123

# Local dev only — points frontend to the Express backend
# Not needed in Vercel (frontend calls /api/* on same origin)
REACT_APP_API_URL=http://localhost:5000/api
